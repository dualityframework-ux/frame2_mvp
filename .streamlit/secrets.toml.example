# Copy this file to .streamlit/secrets.toml and fill in your values.
# secrets.toml is git-ignored and never committed.

# MLB Stats API — no key required for public endpoints,
# but set a user-agent string for rate-limit courtesy:
# [mlb]
# user_agent = "frame2-redsox-history/1.0 (your@email.com)"

# Future: if you add a paid data provider, add credentials here:
# [statsapi]
# api_key = "YOUR_KEY_HERE"
